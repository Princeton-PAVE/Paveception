# Copy this file to `.env` and fill in your HuggingFace access token.
# The `.env` file is gitignored (see .gitignore) so the token stays local.
#
# Get a token at https://huggingface.co/settings/tokens
# (read-only "fine-grained" with "Read access to public gated repos" is enough
#  for DA3NESTED-GIANT-LARGE).

HF_TOKEN=hf_your_token_here
